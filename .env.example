# Copy this file to `.env.local` for local development.
# Local development uses the `aredirlabs-dev` Neon database instance.
#
# For one-time production database setup from your machine, copy to
# `.env.production.local` with the aredirlabs-prod DATABASE_URL and production
# URLs (see README). Never commit `.env.production.local`.
# Production runtime values are set in Vercel project settings.

DATABASE_URL=postgresql://user:password@ep-example.us-west-2.aws.neon.tech/neondb?sslmode=require
BETTER_AUTH_SECRET=replace-with-a-random-string-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
WORKSPACE_ALLOWED_EMAILS=you@example.com,teammate@example.com
